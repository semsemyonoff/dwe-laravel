#!/usr/bin/env sh
# pre-commit hook for {{ .Service }} ({{ .ServiceCfg.Container }})
# LOCAL OVERRIDE — rendered from workspace/templates/git/default.local/pre-commit.tmpl.

set -e

echo "[pre-commit] {{ .Service }}: local override — running Laravel Pint…"

# Run Pint against the staged set, inside the service container.
# Adjust to your toolchain (phpstan, phpunit --filter, etc.).
staged_php=$(git diff --cached --name-only --diff-filter=ACM -- '*.php' || true)
if [ -z "$staged_php" ]; then
  exit 0
fi

# shellcheck disable=SC2086
dwe shell {{ .Service }} -- ./vendor/bin/pint --test $staged_php
