#!/usr/bin/env sh
# pre-commit hook for {{ .Service }} ({{ .ServiceCfg.Container }})
# Generated by `dwe render git` — do not edit by hand.

set -e

echo "[pre-commit] {{ .Service }}: checking staged files…"

# Reject staged files containing trailing whitespace.
staged=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged" ]; then
  bad=$(echo "$staged" | xargs grep -lnE ' +$' 2>/dev/null || true)
  if [ -n "$bad" ]; then
    echo "[pre-commit] trailing whitespace in:" >&2
    echo "$bad" >&2
    exit 1
  fi
fi
