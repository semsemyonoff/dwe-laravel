# Laravel .env — RENDERED by `dwe render config` straight into src/.env from
# this template. Edit the template or the backing vars (vars.db.*); never
# hand-edit the rendered live file.
#
# `${...}` is the DWE config-render shorthand: `${vars.db.user}` resolves the
# merged config. Laravel's OWN `${APP_NAME}` interpolation is a literal that DWE
# must NOT resolve, so it is escaped as `{{ "$" }}{APP_NAME}` → renders to the
# literal `${APP_NAME}` for Laravel to expand at runtime.
#
# APP_KEY=${generated.app_key} replays the key harvested into .dwe/generated.yml
# (empty on the first deploy — `php artisan key:generate` mints it, then the
# harvest step captures it; see workspace/services/main/deploy.yml).
APP_NAME=Laravel
APP_ENV=local
APP_KEY=${generated.app_key}
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://${services.main.hosts.web}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=${vars.db.database}
DB_USERNAME=${vars.db.user}
DB_PASSWORD=${vars.db.password}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="{{ "$" }}{APP_NAME}"

VITE_APP_NAME="{{ "$" }}{APP_NAME}"
