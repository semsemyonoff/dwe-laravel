# Temporary (for pilot only)
legacy/

# DWE
.dwe/
# DB dumps live in backups/db/ — keep the dir, ignore the dumps
backups/db/*
!backups/db/.gitkeep
services/*
volumes/
snapshots/
# Only the generated root .env is ignored — per-service templates in
# configs/services/<svc>/.env ARE tracked (the deployed copy lands under
# services/<svc>/configs/.env, already ignored via services/*).
/.env
workspace/local.yml
workspace/docker.local.yml
workspace/templates/*/*.local/

# tools
.ralphex/

# IDE & OS
.idea/
.vscode/
.zed/
# …but template packs ship their own .vscode/ templates that must stay tracked.
!workspace/templates/**/.vscode/
!workspace/templates/**/.vscode/**
*~
.DS_Store
