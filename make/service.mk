	fi
	@$(call ok,Application key generated for second)

migrate-second:
	@if $(call container-running,$(APP_SECOND_CONTAINER)); then \
		$(DOCKER_COMPOSE) exec -u $$(id -u) -w $(APP_SECOND_DIR_INTERNAL) $(APP_SECOND_CONTAINER) \
