			composer install --ansi --prefer-dist --no-interaction --optimize-autoloader; \
	fi
	@$(call ok,Composer install complete for second)

key-generate-second:
	@if $(call container-running,$(APP_SECOND_CONTAINER)); then \
		$(DOCKER_COMPOSE) exec -u $$(id -u) -w $(APP_SECOND_DIR_INTERNAL) $(APP_SECOND_CONTAINER) \
