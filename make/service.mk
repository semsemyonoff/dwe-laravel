		$(DOCKER_COMPOSE) run --rm --no-deps -u $$(id -u) -w $(APP_SECOND_DIR_INTERNAL) $(APP_SECOND_CONTAINER) \
			php artisan migrate; \
	fi
	@$(call ok,Migrations complete for second)

cli-second:
	@$(DOCKER_COMPOSE) $(mode) -it -w $(APP_SECOND_DIR_INTERNAL) $(APP_SECOND_CONTAINER) bash

cli-second-root:
