#!/usr/bin/env sh
# commit-msg hook for {{ .Service }}
# Generated by `devbox render git` — do not edit by hand.

set -e

msg_file="$1"
subject=$(head -n1 "$msg_file")

# Reject empty / fixup / trivial subjects.
trimmed=$(printf '%s' "$subject" | tr -d '[:space:]')
if [ "${#trimmed}" -lt 5 ]; then
  echo "[commit-msg] subject too short (need at least 5 non-space chars): $subject" >&2
  exit 1
fi
